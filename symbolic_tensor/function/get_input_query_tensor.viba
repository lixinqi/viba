get_input_query_tensor :=
    $output Symbolic[torch.Tensor]
    <- $input Symbolic[torch.Tensor]
    # inline
    <- $todo_like Import[symbolic_tensor/tensor_util/todo_tensor_like.viba]
    <- ($output <- $todo_like <- $input)
    <- ($tmp_dir <- TemporaryDirectory)
    <- $dump_view Import[symbolic_tensor/tensor_util/dump_view.viba]
    <- (void <- $dump_view <- $input <- f"{tmp_dir}/input_view")
    <- (void <- $dump_view <- $output <- f"{tmp_dir}/output_view")
    <- ($prompt str <- '''
        # please polish the following prompt
        you are a semantic grep key word generator.
        given the symbolic tensor view in f"{tmp_dir}/input_view".
        please generate the query key words into corresponding file in f"{tmp_dir}/output_view".
        each line in a output file contains only single key word that used for grep/query like things.
        the key words of files are used for calucating simmularity between files.
        all "TODO" in output files should be replaced with key words.
        the length of key words list should be kept small for it's a semantic summary.
    ''')
    <- $llm_query Import[symbolic_tensor/llm_client/coding_agent_query.py]
    <- (void <- $llm_query <- $prompt <- $tmp_dir)

# be carefull there claude code instance called in coding_agent_query.
# make sure env var CLAUDECODE unset.