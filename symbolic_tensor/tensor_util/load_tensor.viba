load_tensor :=
    Symbolic[torch.Tensor]
    <- $load_dir str
    <- $relative_to str
    # inline
    <- Assert[IsADumpedTensorDir[$load_dir]]
    <- $nested_data from_load_dir
    <- Import[symbolic_tensor/tensor_util/make_tensor.viba]
    <- $shape from_load_dir
    <- $stride from_load_dir
    <- torch.Tensor.as_strided

# roundtrip tests with symbolic_tensor/tensor_util/dump_tensor.viba