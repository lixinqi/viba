slice_view :=
    $ret Symbolic[torch.Tensor]
    <- $input Symbolic[torch.Tensor]
    <- $slice_tensors list[torch.Tensor | slice | int]
    # inline
    <- Assert[len($slice_tensors) == len($input.size)]
    <- $make_tensor Import[symbolic_tensor/tensor_util/make_tensor.viba]
    <- ($selected_paths NestedList[pathlib.Path] <- $input <- $slice_tensors)
    <- ($ret <- $make_tensor <- $selected_paths <- $symlink True)
    <- Assert[len(ret.size) == len($input.size) - count_0_rank_tensor_elements[$slice_tensors] - count_int_element[$slice_tensors]]