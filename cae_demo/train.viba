main :=
    void
    <- ()
    # inline
    <- $model DemoModel
    <- $data_set ./dataset/
    <- $dataloader Import[symbolic_tensor/data_loader/sole_file_batch_data_loader.py]
    <- Import[symbolic_tensor/function/copy.py]
    <- $dst_relative_to /tmp/tensor_data
    <- $get_loss Import[symbolic_tensor/function/get_diff_ratio.py].get_diff_ratio
    <- '''
        5 train iters
        validation: convergence trend
    '''