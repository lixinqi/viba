
# Tensor is only for comprehension. do not generate
Tensor[T] := torch.Tensor[
    $shape (batch_size, max_use_count, feature_len), 
    $dtype uint8, 
    $file_content_type T
]

get_diff_ratio_forward :=
    $output 'torch.Tensor[shape=(batch_size,), dtype=float32]'
    <- $actual Tensor[T]
    <- $expected Tensor[T, $require_grads False]
    # inline
    <- Getter[Tensor.st_relative_to]
    <- $convert_st_tensor_to_file_contents ImportFrom["viba/st/tensor_util/convert_st_tensor_to_file_contents"]
    <- '''
        # use diff cli to get diff_file of `actual` and `expected`
        diff_ratio = num_lines(diff_file) / num_lines(expected_file)
        return diff_ratio
    '''

get_diff_ratio_backward :=
    ($actual_grad Tensor[Diff], $expected_grad None)
    <- $output_grad 'torch.Tensor[shape=(batch_size,), dtype=float32]'
    <- $actual Tensor[T]
    <- $expected Tensor[T, $require_grads False]
    # inline
    <- Getter[Tensor.st_relative_to]
    <- $convert_st_tensor_to_file_contents ImportFrom["viba/st/tensor_util/convert_st_tensor_to_file_contents"]
    <- '''
        # use diff cli to get diff_file of `actual` and `expected`
    '''
    <- ($actual_grad <- Import["viba/st/tensor_util/convert_file_contents_to_st_tensor.py"].convert_file_contents_to_st_tensor <- ...)
    <- Setter[Tensor.st_relative_to]
    <- Setter[Tensor.st_file_content_type]
    <- ($actual_grad.shape <- copy <- $actual.shape)
    <- ($actual_grad.st_diff_coefficient_tensor <- copy <- $output_grad)


GetDiffRatio :=
    torch.autograd.Function
    * $forward (
        ...
        <- ...
        # inline
        <- get_diff_ratio_forward
    )
    * $backward (
        ...
        <- ...
        <- get_diff_ratio_backward
    )

get_diff_ratio := GetDiffRatio.apply

