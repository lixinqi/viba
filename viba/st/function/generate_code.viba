
# Tensor is only for comprehension. do not generate
Tensor[T] := torch.Tensor[
    $shape (batch_size, max_use_count, feature_len), 
    $dtype uint8, 
    $file_content_type T
]

generate_code_forward :=
    $output Tensor[$output_file_content_type]
    <- $input Tensor[Viba]
    <- $weight Tensor[Json[list[$key Viba * $value T]]]
    <- $output_file_content_type str
    # inline
    <- Tensor.st_relative_to
    <- $convert_st_tensor_to_file_contents ImportFrom["viba/st/tensor_util/convert_st_tensor_to_file_contents"]
    # see viba/get_all_truncated_vibe_code.*, viba/std_coding_style.py to generate LLMs prompt
    # generate 7 viba segment for each ExponentChain
    <- $get_output_json_for_each_batch (Viba <- '''
    unset CLAUDECODE && claude -p '{prompt} {output_file_content_type} {weight_file_content} {input_file_content}'
    ''')
    <- ($output.shape[1] <- $input.shape[1])
    <- Import["viba/st/tensor_util/convert_file_contents_to_st_tensor.py"].convert_file_contents_to_st_tensor
    <- Setter[Tensor.st_relative_to]
    <- ($output.st_file_content_type <- output_file_content_type)

generate_code_backward :=
    $ret (
        $input_grad Tensor[Diff[Viba]], 
        $weigh_grad Tensor[Json[list[$key Diff[Viba] * $value Diff[T]]]]
    )
    <- $output_grad Tensor[Diff[T]]
    <- $input Tensor[Viba]
    <- $weight Tensor[Json[list[$key Viba * $value T]]]
    # inline
    <- Tensor.st_relative_to
    <- Import["viba/st/tensor_util/convert_st_tensor_to_file_contents"].convert_st_tensor_to_file_contents
    <- $get_input_grad (Viba <- '''
    unset CLAUDECODE && claude -p '{prompt} {all_weights_file_content} {input_file_content} {output_grad_file_content}'
    ''')
    <- $get_weight_grad_json (Json[list[$key Diff[Viba] * $value Diff[T]]] <- '''
    unset CLAUDECODE && claude -p '{prompt} {all_weights_file_content} {input_file_content} {output_grad_file_content}'
    ''')
    <- ($input_grad.shape[1] <- $input.shape[1])
    <- Import["viba/st/tensor_util/convert_file_contents_to_st_tensor.py"].convert_file_contents_to_st_tensor
    <- Setter[Tensor.st_relative_to]
    <- Setter[Tensor.st_file_content_type]


GenerateCode :=
    torch.autograd.Function
    * $forward (
        ...
        <- ...
        # inline
        <- generate_code_forward
    )
    * $backward (
        ...
        <- ...
        <- generate_code_backward
    )

generate_code := GenerateCode.apply

